WEB_USER=admin
WEB_PASS=change-this-web-password
PROXY_USER=proxy
PROXY_PASS=change-this-proxy-password
AGENT_TOKEN=change-this-agent-token

# Public URL that browsers and remote VPS agents use to reach the controller.
PUBLIC_BASE_URL=http://your-controller-host:2055

# Local published controller port.
PORT=2055

# Agent-side controller URL. Use a public URL on remote VPS nodes.
AGENT_CONTROLLER_URL=http://your-controller-host:2055

# Optional: override the host/port returned by /api/proxies.
# Required when using Koyeb TCP Proxy, because Koyeb exposes a generated
# proxy host and public port instead of your container's internal 7920 port.
PROXY_ADVERTISE_HOST=
PROXY_ADVERTISE_PORT=
